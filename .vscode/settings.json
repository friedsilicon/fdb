// Place your settings in this file to overwrite default and user settings.
{
    "cmake.buildDirectory": "${workspaceRoot}/../vsc-build",
    "cmake.installPrefix": "${workspaceRoot}/../vsc-install",
    "cmake.generator": "Ninja",
    "cmake.configureEnvironment": {},
    "cmake.configureArgs": [
       "-DWITH_COVERAGE=ON"
    ],
    "files.associations": {
        "cstdlib": "cpp",
        "fdb_log.h": "c",
        "fdb_private.h": "c",
        "string": "c",
        "string_view": "c",
        "vector": "c",
        "algorithm": "cpp",
        "locale": "c",
        "typeinfo": "cpp",
        "skiplist.h": "c",
        "fdb_hexdump.h": "c"
    },
    "chat.mcp.serverSampling": {
        "fdb/.vscode/mcp.json: trello": {
            "allowedModels": [
                "copilot/auto",
                "copilot/gpt-4.1",
                "copilotcli/gpt-4.1",
                "copilot/gpt-4o"
            ]
        }
    }
}